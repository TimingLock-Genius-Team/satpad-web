# Copy to .env.local and adjust if needed.

# Optional: full API origin (e.g. https://api.example.com). Leave unset for local dev so
# the Next dev server proxies to BACKEND_PROXY_TARGET (no browser CORS).
# NEXT_PUBLIC_API_BASE_URL=

# Must match backend DEPLOYMENT_NETWORK / API network name.
NEXT_PUBLIC_DEFAULT_NETWORK=sepolia

# Optional RPC overrides for wagmi.
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# NEXT_PUBLIC_HASHKEYTEST_RPC_URL=
# NEXT_PUBLIC_XLAYER_RPC_URL=

# Pinata JWT for uploading images/metadata to IPFS.
# Create one at https://app.pinata.cloud/developers/api-keys
# NEXT_PUBLIC_PINATA_JWT=

# Used only by next.config.mjs rewrites (where the dev proxy forwards /api, /health, /swagger).
# Must match the local backend origin.
BACKEND_PROXY_TARGET=http://127.0.0.1:3340
